# PostgreSQL connection string (Supabase: Project Settings > Database)
# Use the direct connection for migrations and a pooler URL for serverless deployments.
DATABASE_URL="postgresql://postgres:password@localhost:5432/foot_r?schema=public"

# 42 OAuth application credentials (server-only; never prefix with NEXT_PUBLIC_)
FORTY_TWO_UID="your-42-application-uid"
FORTY_TWO_SECRET="your-42-application-secret"

# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-auth-secret"

# Supabase Storage only. Keep the service-role key server-side.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
